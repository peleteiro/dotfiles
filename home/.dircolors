# Dark Pastel theme for dircolors
# Soft, muted colors optimized for dark terminal backgrounds
# Uses 256-color palette for richer differentiation

# Terminal types
TERM Eterm
TERM ansi
TERM color-xterm
TERM con132x25
TERM con132x30
TERM con132x43
TERM con132x60
TERM con80x25
TERM con80x28
TERM con80x30
TERM con80x43
TERM con80x50
TERM con80x60
TERM cons25
TERM console
TERM cygwin
TERM dtterm
TERM eterm-color
TERM gnome
TERM gnome-256color
TERM jfbterm
TERM konsole
TERM konsole-256color
TERM kterm
TERM linux
TERM linux-c
TERM mach-color
TERM mlterm
TERM putty
TERM putty-256color
TERM rxvt
TERM rxvt-256color
TERM rxvt-cygwin
TERM rxvt-cygwin-native
TERM rxvt-unicode
TERM rxvt-unicode-256color
TERM rxvt-unicode256
TERM screen
TERM screen-256color
TERM screen-256color-bce
TERM screen-bce
TERM screen-w
TERM screen.rxvt
TERM screen.linux
TERM st
TERM st-256color
TERM terminator
TERM tmux
TERM tmux-256color
TERM vt100
TERM xterm
TERM xterm-16color
TERM xterm-256color
TERM xterm-88color
TERM xterm-color
TERM xterm-debian
TERM xterm-kitty
TERM xterm-ghostty
TERM alacritty

# Attribute codes:
#   00=none 01=bold 02=dim 03=italic 04=underscore 05=blink 07=reverse 08=concealed
# 256-color:
#   38;5;N = foreground    48;5;N = background

RESET 0
NORMAL 00

# --- Core file types ---
FILE   00                # regular file
DIR    01;38;5;111       # directory — soft blue
LINK   38;5;116          # symbolic link — soft teal
ORPHAN 38;5;203;48;5;52  # broken symlink — coral on dark red
MISSING 38;5;203;48;5;52 # target of broken symlink
MULTIHARDLINK 00

# --- Special files ---
FIFO  38;5;179           # pipe — muted gold
SOCK  38;5;175           # socket — dusty rose
DOOR  38;5;175           # door — dusty rose
BLK   38;5;180;48;5;236  # block device — tan on dark gray
CHR   38;5;180;48;5;236  # character device — tan on dark gray

# --- Permissions ---
EXEC            01;38;5;114  # executable — soft green
SETUID          38;5;255;48;5;131  # setuid — white on muted red
SETGID          38;5;235;48;5;179  # setgid — dark on muted gold
CAPABILITY      38;5;255;48;5;131
STICKY          38;5;255;48;5;67   # sticky — white on steel blue
OTHER_WRITABLE  01;38;5;111;48;5;236 # other-writable dir — blue on dark
STICKY_OTHER_WRITABLE 01;38;5;111;48;5;236

